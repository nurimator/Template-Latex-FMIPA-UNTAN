\ProvidesPackage{thesis_style}

% ================= PACKAGES =================
\usepackage{fontspec}
\setmainfont{Times New Roman}
\usepackage{geometry}
\usepackage{graphicx}
\usepackage{setspace}
\usepackage{booktabs}
\usepackage{titlesec}
\usepackage{indentfirst}
\setlength{\parindent}{1cm} % Set paragraph indentation to 1 cm
\usepackage[labelfont=bf, textfont=md, labelsep=space, format=hang]{caption}
\usepackage[textfont=md, labelsep=space, format=hang]{caption}
\captionsetup[figure]{labelfont=bf} % Figure uses Bold, 10pt spacing
\captionsetup[table]{labelfont=md, skip=0pt}  % Table not Bold, 10pt spacing

% Prevent word hyphenation and allow space stretching
\hyphenpenalty=10000
\exhyphenpenalty=10000
\sloppy

\usepackage{amsmath}
\usepackage{fancyhdr}
\usepackage[normalem]{ulem} % For better underline
\usepackage{enumitem} % To set list spacing
\usepackage{tocloft}
\usepackage{etoolbox} % For environment modification

% Remove extra spacing on list to follow 1.5 spacing
\setlist{nosep, leftmargin=*} 

% ================= TOC STYLING =================
\renewcommand{\cftchapfont}{\normalfont}    % Chapter title not bold
\renewcommand{\cftchappagefont}{\normalfont}% Chapter page number not bold
\renewcommand{\cftchapdotsep}{\cftdotsep}   % Dots for chapters
\renewcommand{\cftchappresnum}{CHAPTER\ }       % Add CHAPTER word
\setlength{\cftchapnumwidth}{6em}           % Width of chapter number space
\renewcommand{\cftdotsep}{1}                % Density of dots
\setlength{\cftbeforechapskip}{0pt}         % Uniform vertical spacing (0pt)

% Centering and bolding List Titles (TOC, LOF, LOT)
\renewcommand{\cfttoctitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftaftertoctitle}{\hspace*{\fill}\par\vspace{20pt}\hfill Page\par}
\setlength{\cftaftertoctitleskip}{0pt}

\renewcommand{\cftloftitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftafterloftitle}{\hspace*{\fill}\par\vspace{20pt}}
\setlength{\cftafterloftitleskip}{0pt}

\renewcommand{\cftlottitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftafterlottitle}{\hspace*{\fill}\par\vspace{20pt}}
\setlength{\cftafterlottitleskip}{0pt}

% ================= GEOMETRY =================
\geometry{top=4cm, bottom=3cm, left=4cm, right=3cm}

% ================= STYLING =================

% Formatting chapters to look like "CHAPTER I"
\titleformat{\chapter}[display]
  {\normalfont\large\bfseries\centering}{\chaptertitlename\ \Roman{chapter}}{-4pt}{\large}
\titlespacing*{\chapter}{0pt}{-20pt}{20pt}

\titleformat{\section}
  {\normalfont\normalsize\bfseries}{\thesection}{1em}{}
\titlespacing*{\section}{0pt}{2ex plus 1ex minus .2ex}{0.1ex}

\titleformat{\subsection}
  {\normalfont\normalsize}{\thesubsection}{1em}{\uline}
\titlespacing*{\subsection}{0pt}{1.5ex plus 1ex minus .2ex}{0.1ex}

\titleformat{\subsubsection}
  {\normalfont\normalsize}{\thesubsubsection}{1em}{\uline}
\titlespacing*{\subsubsection}{0pt}{1.5ex plus 1ex minus .2ex}{0.1ex}


% ================= BIBLIOGRAPHY STYLING =================
\usepackage[backend=biber, style=authoryear, sorting=nyt, maxcitenames=2, maxbibnames=99, giveninits=true, dashed=false]{biblatex}
\addbibresource{references.bib}

% Set 1.0 spacing and 1cm hanging indentation
\setlength{\bibhang}{1cm}
\renewcommand{\bibfont}{\setstretch{1.0}}
\setlength{\bibnamesep}{1ex}

% CUSTOM STYLE: Change separator between elements to comma
\renewcommand*{\newunitpunct}{\addcomma\space}

% CUSTOM STYLE: Remove parentheses on year
\renewbibmacro*{date+extradate}{%
  \iffieldundef{labelyear}
    {}
    {\printtext{\printfield{labelyear}\printfield{extradate}}}}

% CUSTOM STYLE: Remove "In:" word for journals
\renewbibmacro{in:}{}

% CUSTOM STYLE: Set Volume, Number, and Page order
\DeclareFieldFormat[article]{volume}{#1}
\DeclareFieldFormat[article]{number}{\mkbibparens{#1}}
\DeclareFieldFormat[article]{pages}{#1}

% Set References title to use Chapter* style
\defbibheading{bibliography}[\bibname]{%
  \chapter*{REFERENCES}%
  \markboth{REFERENCES}{REFERENCES}%
  \addcontentsline{toc}{chapter}{REFERENCES}%
}

% Translating labels to English
\renewcommand{\contentsname}{TABLE OF CONTENTS}
\renewcommand{\listfigurename}{LIST OF FIGURES}
\renewcommand{\listtablename}{LIST OF TABLES}
\renewcommand{\chaptername}{CHAPTER}
\renewcommand{\figurename}{Figure}
\renewcommand{\tablename}{Table}
\renewcommand{\bibname}{REFERENCES}


% Header and Footer Styling
\pagestyle{fancy}
\fancyhf{}
\fancyhead[R]{\thepage} % Page number on Top Right for regular pages
\renewcommand{\headrulewidth}{0pt}

% Redefining "plain" style for chapter first pages
\fancypagestyle{plain}{
  \fancyhf{}
  \fancyfoot[C]{\thepage} % Page number on Bottom Center for chapter starts
  \renewcommand{\headrulewidth}{0pt}
}

\endinput
