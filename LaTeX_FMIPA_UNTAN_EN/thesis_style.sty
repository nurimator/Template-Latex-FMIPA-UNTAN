\ProvidesPackage{thesis_style}

% ================= PACKAGES =================
\usepackage{fontspec}
\setmainfont{Times New Roman}
\usepackage{geometry}
\usepackage{graphicx}
\usepackage{setspace}
\usepackage{booktabs}
\usepackage{titlesec}
\usepackage{indentfirst}
\setlength{\parindent}{1cm} % Paragraph indentation is set to 1 cm
\usepackage[labelfont=bf, textfont=md, labelsep=space, format=hang]{caption}
\usepackage{subcaption}
\captionsetup[figure]{labelfont=bf} % Figures use Bold, 10pt spacing
\captionsetup[table]{labelfont=md, skip=0pt}  % Tables use non-Bold, 10pt spacing

% Prevention of word hyphenation and allowance for space stretching
\hyphenpenalty=10000
\exhyphenpenalty=10000
\sloppy

\usepackage{amsmath}
\usepackage{fancyhdr}
\usepackage[normalem]{ulem} % Use of better underline
\usepackage{enumitem} % Adjustment of list spacing
\usepackage{tocloft}
\usepackage{etoolbox} % Environment modification

% Removal of extra spacing on list for 1.5 spacing
\setlist{nosep, leftmargin=*} 

% ================= TOC STYLING =================
\setcounter{tocdepth}{2}                    % Limitation to 3 levels: Chapter, Section, Subsection
\renewcommand{\cftchapfont}{\normalfont}    % Chapter title is not bold
\renewcommand{\cftchappagefont}{\normalfont}% Chapter page number is not bold
\renewcommand{\cftchapdotsep}{\cftdotsep}   % Dots for chapters
\renewcommand{\cftchapleader}{\normalfont\cftdotfill{\cftchapdotsep}} % Normal dots for chapters
\renewcommand{\cftdotsep}{1}                % Density of dots
\setlength{\cftbeforechapskip}{0.5\baselineskip} % 1.5 spacing gap before new chapter

% --- SECTION & SUBSECTION: FIXED WIDTH (ALIGNED) ---
\setlength{\cftsecnumwidth}{2.2em}
\setlength{\cftsubsecnumwidth}{2.6em}

% --- CHAPTER: FLUID (NO FIXED WIDTH) ---
% Chapter titles follow the number with a normal space (no fixed width)
\makeatletter
\renewcommand{\l@chapter}[2]{%
  \ifnum \c@tocdepth >\m@ne
    \addpenalty{-\@highpenalty}%
    \vskip \cftbeforechapskip
    {\leftskip \cftchapindent\relax
     \rightskip \@tocrmarg
     \parfillskip -\rightskip
     \parindent \cftchapindent\relax\@afterindenttrue
     \interlinepenalty\@M
     \leavevmode
     \let\@tempa\numberline
     \renewcommand{\numberline}[1]{\chaptername\ ##1\ }% Usage of normal space
     {#1}\nobreak{\normalfont\cftchapfillnum{#2}}}%
  \fi}
\makeatother
% ---------------------------------------

% Centering and bolding of List Titles (TOC, LOF, LOT)
\renewcommand{\cfttoctitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftaftertoctitle}{\hspace*{\fill}\par\vspace{20pt}\hfill Page\par}
\setlength{\cftaftertoctitleskip}{0pt}

\renewcommand{\cftloftitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftafterloftitle}{\hspace*{\fill}\par\vspace{20pt}\hfill Page\par}
\setlength{\cftafterloftitleskip}{0pt}
\renewcommand{\cftfigpresnum}{Figure }
\setlength{\cftfignumwidth}{4.6em}
\setlength{\cftbeforefigskip}{0pt}

\renewcommand{\cftlottitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftafterlottitle}{\hspace*{\fill}\par\vspace{20pt}\hfill Page\par}
\setlength{\cftafterlottitleskip}{0pt}
\renewcommand{\cfttabpresnum}{Table }
\setlength{\cfttabnumwidth}{4.2em}
\setlength{\cftbeforetabskip}{0pt}

% ================= APPENDIX LIST STYLING =================
\newcommand{\listappendixname}{LIST OF APPENDICES}
\newlistof{appendix}{apx}{\listappendixname}
\renewcommand{\cftapxtitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftafterapxtitle}{\hspace*{\fill}\par\vspace{20pt}\hfill Page\par}
\setlength{\cftafterapxtitleskip}{0pt}
\setlength{\cftbeforeappendixskip}{0pt}
\renewcommand{\cftappendixdotsep}{\cftdotsep}
\setlength{\cftappendixnumwidth}{6em}

% Command for adding appendix items
\newcounter{appendixcount}
\newcommand{\appendixitem}[1]{%
    \stepcounter{appendixcount}%
    \noindent Appendix \theappendixcount. #1\par
    \addcontentsline{apx}{appendix}{Appendix \theappendixcount. #1}%
}

% ================= GEOMETRY =================
\geometry{top=4cm, bottom=3cm, left=4cm, right=3cm}

% ================= STYLING =================

% ================= RESET BASIC CHAPTER NUMBERING TO ROMAN =================
% Automatic reading of Roman numerals by the Table of Contents (TOC)
\renewcommand{\thechapter}{\Roman{chapter}} 

% Usage of Arabic chapter prefixes for Figure, Table, and Equation numbers (1.1, 1.2)
% even though the Chapter number itself is Roman.
\renewcommand{\thefigure}{\arabic{chapter}.\arabic{figure}}
\renewcommand{\thetable}{\arabic{chapter}.\arabic{table}}
\renewcommand{\theequation}{\arabic{chapter}.\arabic{equation}}

% (Optional) Section numbers remaining in Arabic format (1.1, 1.1.1)
\renewcommand{\thesection}{\arabic{chapter}.\arabic{section}}
\renewcommand{\thesubsection}{\thesection.\arabic{subsection}}
% ================= CHAPTER TITLE STYLING =================
% Usage of original number (\thechapter) for numbered chapters (\chapter)
\titleformat{\chapter}[display]
  {\normalfont\large\bfseries\centering}{\chaptertitlename\ \thechapter}{-4pt}{\large}
\titlespacing*{\chapter}{0pt}{-20pt}{20pt}

% Special settings for unnumbered chapters (\chapter*)
% Such as TABLE OF CONTENTS, LIST OF FIGURES, REFERENCES, etc.
\titleformat{name=\chapter,numberless}[display]
  {\normalfont\large\bfseries\centering}{}{-4pt}{\large}
\titlespacing*{name=\chapter,numberless}{0pt}{-20pt}{20pt}

\titleformat{\section}
  {\normalfont\normalsize\bfseries}{\thesection}{1em}{}
\titlespacing*{\section}{0pt}{2ex plus 1ex minus .2ex}{0.1ex}

\titleformat{\subsection}
  {\normalfont\normalsize}{\thesubsection}{0.5em}{\uline}
\titlespacing*{\subsection}{0pt}{0pt}{0.1ex}

\titleformat{\subsubsection}
  {\normalfont\normalsize}{\thesubsubsection}{0.5em}{\uline}
\titlespacing*{\subsubsection}{0pt}{0pt}{0.1ex}


% ================= BIBLIOGRAPHY STYLING =================
\usepackage[backend=biber, style=authoryear, sorting=nyt, maxcitenames=2, maxbibnames=99, giveninits=true, dashed=false, doi=false, uniquename=false, uniquelist=false]{biblatex}
\addbibresource{references.bib}

% Settings for 1.0 spacing and 1cm hanging indentation
\setlength{\bibhang}{1cm}
\renewcommand{\bibfont}{\setstretch{1.0}}
\setlength{\bibnamesep}{1ex}

% CUSTOM STYLE: Element separator is changed to a comma
\renewcommand*{\newunitpunct}{\addcomma\space}

% CUSTOM STYLE: Remove quotation marks from article titles (and similar entries)
\DeclareFieldFormat[article,inbook,incollection,inproceedings,patent,thesis,unpublished]{title}{#1}

% CUSTOM STYLE: Removal of parentheses from the year
\renewbibmacro*{date+extradate}{%
  \iffieldundef{labelyear}
    {}
    {\printtext{\printfield{labelyear}\printfield{extradate}}}}

% CUSTOM STYLE: Removal of "In:" for journals
\renewbibmacro{in:}{}

% CUSTOM STYLE: Volume, Number, and Page order settings
\DeclareFieldFormat[article]{volume}{#1}
\DeclareFieldFormat[article]{number}{\mkbibparens{#1}}
\DeclareFieldFormat[article]{pages}{#1}

% References title is set to use the Chapter* style
\defbibheading{bibliography}[\bibname]{%
  \chapter*{REFERENCES}%
  \markboth{REFERENCES}{REFERENCES}%
  \addcontentsline{toc}{chapter}{REFERENCES}%
}

% Label translations to English
\renewcommand{\contentsname}{TABLE OF CONTENTS}
\renewcommand{\listfigurename}{LIST OF FIGURES}
\renewcommand{\listtablename}{LIST OF TABLES}
\renewcommand{\chaptername}{CHAPTER}
\renewcommand{\figurename}{Figure}
\renewcommand{\tablename}{Table}
\renewcommand{\bibname}{REFERENCES}


% Header and Footer Styling
\setlength{\headheight}{15pt}
\fancypagestyle{fancy}{
  \fancyhf{}
  \fancyhead[R]{\thepage}
  \renewcommand{\headrulewidth}{0pt}
}

% Redefinition of "plain" style for chapter first pages
\fancypagestyle{plain}{
  \fancyhf{}
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0pt}
}

