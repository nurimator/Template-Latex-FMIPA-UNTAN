  \fancyhf{}
  \fancyhead[R]{\thepage} % Nomor halaman di Kanan Atas untuk halaman reguler
  \renewcommand{\headrulewidth}{0pt}
}

% Redefinisi gaya "plain" untuk halaman pertama bab
\fancypagestyle{plain}{
  \fancyhf{}
