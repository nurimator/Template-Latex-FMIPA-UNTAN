% ================= TOC STYLING =================
\setcounter{tocdepth}{2}                    % Pembatasan hingga 3 tingkat: Bab (0), Section (1), Subsection (2)
\renewcommand{\cftchapfont}{\normalfont}    % Judul bab tidak bold
\renewcommand{\cftchappagefont}{\normalfont}% Nomor halaman bab tidak bold
\renewcommand{\cftchapdotsep}{\cftdotsep}   % Titik-titik untuk bab
\renewcommand{\cftchapleader}{\normalfont\cftdotfill{\cftchapdotsep}} % Titik-titik bab tidak bold
\renewcommand{\cftdotsep}{1}                % Kerapatan titik-titik
\setlength{\cftbeforechapskip}{0.5\baselineskip} % Jarak 1.5 spasi sebelum bab baru

% --- SECTION & SUBSECTION: BATAS KERAS (RATA KOLOM) ---
\setlength{\cftsecnumwidth}{2.2em}
\setlength{\cftsubsecnumwidth}{2.6em}

% --- BAB: FLUID (TANPA BATAS KERAS) ---
% Judul bab mengalir setelah nomor tanpa "jarak keras"
\makeatletter
\renewcommand{\l@chapter}[2]{%
  \ifnum \c@tocdepth >\m@ne
    \addpenalty{-\@highpenalty}%
    \vskip \cftbeforechapskip
    {\leftskip \cftchapindent\relax
     \rightskip \@tocrmarg
     \parfillskip -\rightskip
     \parindent \cftchapindent\relax\@afterindenttrue
     \interlinepenalty\@M
     \leavevmode
     \let\@tempa\numberline
     \renewcommand{\numberline}[1]{\chaptername\ ##1\ }% Penggunaan spasi biasa
     {#1}\nobreak{\normalfont\cftchapfillnum{#2}}}%
  \fi}
\makeatother
% --------------------------------------

% Pengaturan agar Judul Daftar (TOC, LOF, LOT) tetap di tengah dan bold
\renewcommand{\cfttoctitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftaftertoctitle}{\hspace*{\fill}\par\vspace{20pt}\hfill Halaman\par}
\setlength{\cftaftertoctitleskip}{0pt}

\renewcommand{\cftloftitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftafterloftitle}{\hspace*{\fill}\par\vspace{20pt}\hfill Halaman\par}
\setlength{\cftafterloftitleskip}{0pt}
\renewcommand{\cftfigpresnum}{Gambar }
\setlength{\cftfignumwidth}{5.2em}
\setlength{\cftbeforefigskip}{0pt}

\renewcommand{\cftlottitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftafterlottitle}{\hspace*{\fill}\par\vspace{20pt}\hfill Halaman\par}
\setlength{\cftafterlottitleskip}{0pt}
\renewcommand{\cfttabpresnum}{Tabel }
\setlength{\cfttabnumwidth}{4.2em}
\setlength{\cftbeforetabskip}{0pt}

% ================= PENGATURAN DAFTAR LAMPIRAN =================
\newcommand{\listappendixname}{DAFTAR LAMPIRAN}
\newlistof{appendix}{apx}{\listappendixname}
\renewcommand{\cftapxtitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftafterapxtitle}{\hspace*{\fill}\par\vspace{20pt}\hfill Halaman\par}
\setlength{\cftafterapxtitleskip}{0pt}
\setlength{\cftbeforeappendixskip}{0pt}
\renewcommand{\cftappendixdotsep}{\cftdotsep}
\setlength{\cftappendixnumwidth}{6em}

% Perintah untuk menambah item lampiran
\newcounter{appendixcount}
\newcommand{\appendixitem}[1]{%
    \stepcounter{appendixcount}%
    \noindent Lampiran \theappendixcount. #1\par
    \addcontentsline{apx}{appendix}{Lampiran \theappendixcount. #1}%
}

% ================= GEOMETRI =================
\geometry{top=4cm, bottom=3cm, left=4cm, right=3cm}

% ================= GAYA PENULISAN =================

% ================= RESET PENOMORAN DASAR BAB JADI ROMAWI =================
% Pembacaan angka Romawi secara otomatis oleh Daftar Isi (TOC)
\renewcommand{\thechapter}{\Roman{chapter}} 

% Penggunaan prefix bab angka Arab untuk nomor Gambar, Tabel, dan Persamaan (1.1, 1.2)
% meskipun nomor Bab menggunakan Romawi.
\renewcommand{\thefigure}{\arabic{chapter}.\arabic{figure}}
\renewcommand{\thetable}{\arabic{chapter}.\arabic{table}}
\renewcommand{\theequation}{\arabic{chapter}.\arabic{equation}}

% (Opsional) Nomor Section tetap menggunakan angka Arab (1.1, 1.1.1)
\renewcommand{\thesection}{\arabic{chapter}.\arabic{section}}
\renewcommand{\thesubsection}{\thesection.\arabic{subsection}}
% ================= GAYA JUDUL BAB =================
% Nomor asli (\thechapter) digunakan untuk bab yang bernomor (\chapter)
\titleformat{\chapter}[display]
  {\normalfont\large\bfseries\centering}{\chaptertitlename\ \thechapter}{-4pt}{\large}
\titlespacing*{\chapter}{0pt}{-20pt}{20pt}

% Pengaturan khusus untuk bab yang tidak bernomor (\chapter*)
% Seperti DAFTAR ISI, DAFTAR GAMBAR, DAFTAR PUSTAKA, dll.
\titleformat{name=\chapter,numberless}[display]
  {\normalfont\large\bfseries\centering}{}{-4pt}{\large}
\titlespacing*{name=\chapter,numberless}{0pt}{-20pt}{20pt}

\titleformat{\section}
  {\normalfont\normalsize\bfseries}{\thesection}{1em}{}
\titlespacing*{\section}{0pt}{2ex plus 1ex minus .2ex}{0.1ex}

\titleformat{\subsection}
  {\normalfont\normalsize}{\thesubsection}{0.5em}{\uline}
\titlespacing*{\subsection}{0pt}{0pt}{0.1ex}

\titleformat{\subsubsection}
  {\normalfont\normalsize}{\thesubsubsection}{0.5em}{\uline}
\titlespacing*{\subsubsection}{0pt}{0pt}{0.1ex}


% ================= BIBLIOGRAPHY STYLING =================
\usepackage[backend=biber, style=authoryear, sorting=nyt, maxcitenames=2, maxbibnames=99, giveninits=true, dashed=false, doi=false, uniquename=false, uniquelist=false]{biblatex}
\addbibresource{pustaka.bib}

% Pengaturan spasi 1.0 dan indentasi gantung 1cm
\setlength{\bibhang}{1cm}
\renewcommand{\bibfont}{\setstretch{1.0}}
\setlength{\bibnamesep}{1ex}

% CUSTOM STYLE: Pemisah antar elemen diubah menjadi koma
\renewcommand*{\newunitpunct}{\addcomma\space}

% CUSTOM STYLE: Penghilangan tanda kurung pada tahun
\renewbibmacro*{date+extradate}{%
  \iffieldundef{labelyear}
    {}
    {\printtext{\printfield{labelyear}\printfield{extradate}}}}

% CUSTOM STYLE: Penghilangan kata "In:" pada jurnal
\renewbibmacro{in:}{}

% CUSTOM STYLE: Pengaturan urutan Volume, Nomor, dan Halaman
\DeclareFieldFormat[article]{volume}{#1}
\DeclareFieldFormat[article]{number}{\mkbibparens{#1}}
\DeclareFieldFormat[article]{pages}{#1}

% Judul Daftar Pustaka diatur menggunakan gaya Chapter*
\defbibheading{bibliography}[\bibname]{%
  \chapter*{DAFTAR PUSTAKA}%
  \markboth{DAFTAR PUSTAKA}{DAFTAR PUSTAKA}%
  \addcontentsline{toc}{chapter}{DAFTAR PUSTAKA}%
}

% Label diterjemahkan ke Bahasa Indonesia
\renewcommand{\contentsname}{DAFTAR ISI}
\renewcommand{\listfigurename}{DAFTAR GAMBAR}
\renewcommand{\listtablename}{DAFTAR TABEL}
\renewcommand{\chaptername}{BAB}
\renewcommand{\figurename}{Gambar}
\renewcommand{\tablename}{Tabel}
\renewcommand{\bibname}{DAFTAR PUSTAKA}


% Header and Footer Styling
\setlength{\headheight}{15pt}
