\ProvidesPackage{skripsi_style}

% ================= PACKAGES =================
\usepackage{fontspec}
\setmainfont{Times New Roman}
\usepackage{geometry}
\usepackage{graphicx}
\usepackage{setspace}
\usepackage{booktabs}
\usepackage{titlesec}
\usepackage{indentfirst}
\setlength{\parindent}{1cm} % Set indentasi paragraf ke 1 cm
\usepackage[labelfont=bf, textfont=md, labelsep=space, format=hang]{caption}
\usepackage[textfont=md, labelsep=space, format=hang]{caption}
\captionsetup[figure]{labelfont=bf} % Gambar pakai Bold, jarak 10pt
\captionsetup[table]{labelfont=md, skip=0pt}  % Tabel tidak Bold, jarak 10pt

% Mencegah pemenggalan kata dan mengizinkan peregangan spasi
\hyphenpenalty=10000
\exhyphenpenalty=10000
\sloppy

\usepackage{amsmath}
\usepackage{fancyhdr}
\usepackage[normalem]{ulem} % Untuk underline yang lebih baik
\usepackage{enumitem} % Untuk mengatur spasi list
\usepackage{tocloft}
\usepackage{etoolbox} % Untuk modifikasi environment

% Menghilangkan spasi tambahan pada list agar mengikuti spasi 1.5
\setlist{nosep, leftmargin=*} 

% ================= TOC STYLING =================
\renewcommand{\cftchapfont}{\normalfont}    % Judul bab tidak bold
\renewcommand{\cftchappagefont}{\normalfont}% Nomor halaman bab tidak bold
\renewcommand{\cftchapdotsep}{\cftdotsep}   % Titik-titik untuk bab
\renewcommand{\cftchappresnum}{BAB\ }       % Tambah kata BAB
\setlength{\cftchapnumwidth}{5em}           % Lebar ruang nomor bab
\renewcommand{\cftdotsep}{1}                % Kerapatan titik-titik
\setlength{\cftbeforechapskip}{0pt}         % Jarak vertikal seragam (0pt)

% Mengatur agar Judul Daftar (TOC, LOF, LOT) tetap di tengah dan bold
\renewcommand{\cfttoctitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftaftertoctitle}{\hspace*{\fill}\par\vspace{20pt}\hfill Halaman\par}
\setlength{\cftaftertoctitleskip}{0pt}

\renewcommand{\cftloftitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftafterloftitle}{\hspace*{\fill}\par\vspace{20pt}}
\setlength{\cftafterloftitleskip}{0pt}

\renewcommand{\cftlottitlefont}{\hspace*{\fill}\normalfont\large\bfseries}
\renewcommand{\cftafterlottitle}{\hspace*{\fill}\par\vspace{20pt}}
\setlength{\cftafterlottitleskip}{0pt}

% ================= GEOMETRY =================
\geometry{top=4cm, bottom=3cm, left=4cm, right=3cm}

% ================= STYLING =================

% Formatting chapters to look like "BAB I"
\titleformat{\chapter}[display]
  {\normalfont\large\bfseries\centering}{\chaptertitlename\ \Roman{chapter}}{-4pt}{\large}
\titlespacing*{\chapter}{0pt}{-20pt}{20pt}

\titleformat{\section}
  {\normalfont\normalsize\bfseries}{\thesection}{1em}{}
\titlespacing*{\section}{0pt}{2ex plus 1ex minus .2ex}{0.1ex}

\titleformat{\subsection}
  {\normalfont\normalsize}{\thesubsection}{1em}{\uline}
\titlespacing*{\subsection}{0pt}{1.5ex plus 1ex minus .2ex}{0.1ex}

\titleformat{\subsubsection}
  {\normalfont\normalsize}{\thesubsubsection}{1em}{\uline}
\titlespacing*{\subsubsection}{0pt}{1.5ex plus 1ex minus .2ex}{0.1ex}


% ================= BIBLIOGRAPHY STYLING =================
\usepackage[backend=biber, style=authoryear, sorting=nyt, maxcitenames=2, maxbibnames=99, giveninits=true, dashed=false]{biblatex}
\addbibresource{pustaka.bib}

% Mengatur agar spasi 1.0 dan indentasi gantung 1cm
\setlength{\bibhang}{1cm}
\renewcommand{\bibfont}{\setstretch{1.0}}
\setlength{\bibnamesep}{1ex}

% CUSTOM STYLE: Mengubah pemisah antar elemen menjadi koma
\renewcommand*{\newunitpunct}{\addcomma\space}

% CUSTOM STYLE: Menghilangkan tanda kurung pada tahun
\renewbibmacro*{date+extradate}{%
  \iffieldundef{labelyear}
    {}
    {\printtext{\printfield{labelyear}\printfield{extradate}}}}

% CUSTOM STYLE: Menghilangkan kata "In:" pada jurnal
\renewbibmacro{in:}{}

% CUSTOM STYLE: Mengatur urutan Volume, Nomor, dan Halaman
\DeclareFieldFormat[article]{volume}{#1}
\DeclareFieldFormat[article]{number}{\mkbibparens{#1}}
\DeclareFieldFormat[article]{pages}{#1}

% Mengatur agar judul Daftar Pustaka menggunakan gaya Chapter*
\defbibheading{bibliography}[\bibname]{%
  \chapter*{DAFTAR PUSTAKA}%
  \markboth{DAFTAR PUSTAKA}{DAFTAR PUSTAKA}%
  \addcontentsline{toc}{chapter}{DAFTAR PUSTAKA}%
}

% Translating labels to Indonesian
\renewcommand{\contentsname}{DAFTAR ISI}
\renewcommand{\listfigurename}{DAFTAR GAMBAR}
\renewcommand{\listtablename}{DAFTAR TABEL}
\renewcommand{\chaptername}{BAB}
\renewcommand{\figurename}{Gambar}
\renewcommand{\tablename}{Tabel}
\renewcommand{\bibname}{DAFTAR PUSTAKA}

% Header and Footer Styling
\pagestyle{fancy}
\fancyhf{}
\fancyhead[R]{\thepage} % Page number on Top Right for regular pages
\renewcommand{\headrulewidth}{0pt}

% Redefining "plain" style for chapter first pages
\fancypagestyle{plain}{
  \fancyhf{}
  \fancyfoot[C]{\thepage} % Page number on Bottom Center for chapter starts
  \renewcommand{\headrulewidth}{0pt}
}

\endinput
